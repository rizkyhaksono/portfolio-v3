NODE_ENV=

DOMAIN=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# EmailJS
NEXT_PUBLIC_EMAIL_JS_PUBLIC_KEY=
NEXT_PUBLIC_EMAIL_JS_SERVICE_ID=
NEXT_PUBLIC_EMAIL_JS_TEMPLATE_ID=

# Github
GH_READ_USER_TOKEN_PERSONAL=

# Dev.to
DEVTO_KEY=

# WakaTime
WAKATIME_API_KEY=

# API
API_URL=
NEXT_PUBLIC_API_URL=

# Resume (Google Drive view link; optional — defaults to portfolio Drive folder)
NEXT_PUBLIC_RESUME_GOOGLE_DRIVE_URL=

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Umami analytics (Site Statistics section on the home page).
# Otherwise Page Views / Visitors / etc. all show 0.
#
# Option A — Umami Cloud: the data API requires a paid Pro plan; on the free Hobby
# plan the key returns 401. Set just the key:
UMAMI_API_KEY=
#
# Option B — Self-hosted Umami (free, all features). See docker-compose.umami.yml.
# Leave UMAMI_API_KEY blank and set these instead:
# UMAMI_API_URL=http://localhost:3010/api
# UMAMI_WEBSITE_ID=your-self-hosted-website-id
# UMAMI_USERNAME=admin
# UMAMI_PASSWORD=your-umami-password
# NEXT_PUBLIC_UMAMI_SRC=http://localhost:3010/script.js
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-self-hosted-website-id

# Spotify (widget + GET /api/spotify) — all three required at runtime
# Scopes: user-read-currently-playing, user-read-recently-played
# Setup: docs/SPOTIFY_SETUP.md
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
# Sidebar profile link when live playback API is unavailable (no Premium)
NEXT_PUBLIC_SPOTIFY_PROFILE_URL=https://open.spotify.com/user/rizkyhaksono

# Stats page (/stats) — public platform usernames
NEXT_PUBLIC_LEETCODE_USERNAME=
NEXT_PUBLIC_CHESS_USERNAME=
NEXT_PUBLIC_NPM_USERNAME=
NEXT_PUBLIC_LETTERBOXD_USERNAME=
